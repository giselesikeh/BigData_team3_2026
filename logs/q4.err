INFO  : Completed compiling command(queryId=hive_20260411000735_e88d9d0a-7607-4e0d-8ff1-4e3e4b63161e); Time taken: 0.183 seconds
INFO  : Executing command(queryId=hive_20260411000735_e88d9d0a-7607-4e0d-8ff1-4e3e4b63161e): CREATE TABLE q4_results
STORED AS PARQUET
AS
SELECT
lp.state AS state,
lp.city AS city,
ap.severity AS severity,
COUNT(*) AS accident_count,
ROUND(AVG(ap.duration_minutes), 2) AS avg_duration_minutes
FROM accidents_part ap
JOIN locations_part lp
ON ap.location_id = lp.id
WHERE lp.state IS NOT NULL
AND lp.city IS NOT NULL
GROUP BY lp.state, lp.city, ap.severity
