INFO  : Completed compiling command(queryId=hive_20260411000720_996254a5-4b92-4dd9-af20-138c57bd73b7); Time taken: 0.123 seconds
INFO  : Executing command(queryId=hive_20260411000720_996254a5-4b92-4dd9-af20-138c57bd73b7): CREATE TABLE q3_results
STORED AS PARQUET
AS
SELECT
CASE
WHEN ap.start_month IN (12, 1, 2) THEN 'Winter'
WHEN ap.start_month IN (3, 4, 5) THEN 'Spring'
WHEN ap.start_month IN (6, 7, 8) THEN 'Summer'
WHEN ap.start_month IN (9, 10, 11) THEN 'Autumn'
ELSE 'Unknown'
END AS season,
ap.severity AS severity,
COUNT(*) AS accident_count,
ROUND(AVG(ap.duration_minutes), 2) AS avg_duration_minutes
FROM accidents_part ap
WHERE ap.start_month IS NOT NULL
GROUP BY
CASE
WHEN ap.start_month IN (12, 1, 2) THEN 'Winter'
WHEN ap.start_month IN (3, 4, 5) THEN 'Spring'
WHEN ap.start_month IN (6, 7, 8) THEN 'Summer'
WHEN ap.start_month IN (9, 10, 11) THEN 'Autumn'
ELSE 'Unknown'
END,
ap.severity
